{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "analyse",
      "inherits": "debug",
      "cacheVariables": {
        "ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "OFF",
        "BUILD_EXAMPLES": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "debug"
    },
    {
      "name": "build-analyse",
      "configurePreset": "analyse"
    },
    {
      "name": "build-release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "test-debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "dev",
      "displayName": "Configure + Build (Debug)",
      "steps": [
        { "type": "configure", "name": "debug" },
        { "type": "build",     "name": "build-debug" }
      ]
    },
    {
      "name": "analyse",
      "displayName": "Configure + Build + Static Analysis (Debug)",
      "steps": [
        { "type": "configure", "name": "debug" },
        { "type": "build",     "name": "build-analyse" }
      ]
    },
    {
      "name": "ship",
      "displayName": "Configure + Build (Release)",
      "steps": [
        { "type": "configure", "name": "release" },
        { "type": "build",     "name": "build-release" }
      ]
    },
    {
      "name": "test",
      "displayName": "Configure + Build + Test (Debug)",
      "steps": [
        { "type": "configure", "name": "debug" },
        { "type": "build", "name": "build-debug" },
        { "type": "test", "name": "test-debug" }
      ]
    }
  ]
}
